# PostgreSQL — asyncpg driver
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mergetone

# Used to derive the Fernet encryption key for token storage
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Spotify OAuth
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# Apple Music
# Requires an Apple Developer account with a MusicKit identifier
# https://developer.apple.com/documentation/musickit
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
# Path to the .p8 private key file downloaded from Apple Developer
APPLE_PRIVATE_KEY_PATH=./secrets/apple_music.p8
